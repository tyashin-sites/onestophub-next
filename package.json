{
  "name": "onestophub-next",
  "version": "0.1.0",
  "private": true,
  "description": "OneStopHub storefront — Tyashin-managed Next.js (App Router) site running on Cloudflare Workers via OpenNext.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "preview": "npx @opennextjs/cloudflare build && npx wrangler dev",
    "deploy": "npx @opennextjs/cloudflare build && npx wrangler deploy"
  },
  "dependencies": {
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@opennextjs/cloudflare": "^1.0.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.3.0",
    "lucide-react": "^0.400.0",
    "sonner": "^1.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "tailwindcss": "^3.4.17",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20",
    "wrangler": "^4.0.0"
  }
}
